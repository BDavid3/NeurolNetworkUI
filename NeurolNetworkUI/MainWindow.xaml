<Window x:Class="NeurolNetworkUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeurolNetworkUI"
        mc:Ignorable="d"
        Background="Black"
        Title="Neural Network UI">

    <StackPanel Margin="20"
                Background="Black">
        <TextBlock Text="Draw a digit"
                 Foreground="White"
                 FontSize="18"
                 Margin="0,0,0,12"/>
        <Border BorderBrush="#444444"
                BorderThickness="1"
                HorizontalAlignment="Left">
            <ItemsControl x:Name="PixelGrid"
                          Width="448"
                          Height="448">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>
        <Button Content="Reset"
                Width="100"
                Height="20"
                HorizontalAlignment="Left"
                Click="Reset_Click"/>
    </StackPanel>
    
</Window>
